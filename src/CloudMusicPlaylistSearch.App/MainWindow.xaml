<Window x:Class="CloudMusicPlaylistSearch.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="CloudMusic Playlist Search Prototype"
        Width="1100"
        Height="760"
        MinWidth="920"
        MinHeight="620"
        Loaded="MainWindow_OnLoaded"
        Background="#0F141A">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#ECF2F8" />
        </Style>

        <Style x:Key="MutedTextBlockStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#9DAAB8" />
        </Style>

        <Style x:Key="ValueTextBlockStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="ResultsGridHeaderStyle" TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="#0C1117" />
            <Setter Property="Foreground" Value="#DDE8F2" />
            <Setter Property="BorderBrush" Value="#233240" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="ResultsListViewItemStyle" TargetType="ListViewItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#F3F8FD" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6,8" />
            <Setter Property="Margin" Value="0,2,0,0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <GridViewRowPresenter Margin="{TemplateBinding Padding}"
                                                  VerticalAlignment="Center"
                                                  Content="{TemplateBinding Content}"
                                                  Columns="{TemplateBinding GridView.ColumnCollection}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#182430" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#24374A" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#F4B183" />
                                <Setter Property="Foreground" Value="#F8FBFF" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True" />
                                    <Condition Property="Selector.IsSelectionActive" Value="False" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="ItemBorder" Property="Background" Value="#24374A" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#F4B183" />
                                <Setter Property="Foreground" Value="#F8FBFF" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Padding="20"
                Background="#15202B"
                BorderBrush="#233240"
                BorderThickness="1"
                CornerRadius="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontSize="28" FontWeight="Bold" Text="Current Playlist Search" />
                    <TextBlock Margin="0,8,0,0"
                               Style="{StaticResource MutedTextBlockStyle}"
                               Text="原型阶段先打通本地 playingList 解析、内存搜索和基础调试界面。" />
                </StackPanel>

                <Button x:Name="ReloadButton"
                        Grid.Column="1"
                        Width="120"
                        Height="40"
                        Margin="24,0,0,0"
                        Padding="12,0"
                        Background="#F4B183"
                        BorderThickness="0"
                        Click="ReloadButton_OnClick"
                        Content="重新加载"
                        Foreground="#1E1B18"
                        FontWeight="SemiBold" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,18,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border Grid.Row="0"
                    Grid.Column="0"
                    Padding="18,16"
                    Background="#121923"
                    BorderBrush="#233240"
                    BorderThickness="1"
                    CornerRadius="14">
                <StackPanel>
                    <TextBlock Style="{StaticResource MutedTextBlockStyle}" Text="搜索歌曲名或歌手" />
                    <TextBox x:Name="SearchTextBox"
                             Margin="0,10,0,0"
                             Padding="14,10"
                             Background="#0C1117"
                             BorderBrush="#314557"
                             BorderThickness="1"
                             FontSize="18"
                             Foreground="#F8FBFF"
                             TextChanged="SearchTextBox_OnTextChanged"
                             KeyDown="SearchTextBox_OnKeyDown" />
                </StackPanel>
            </Border>

            <Border Grid.Row="0"
                    Grid.Column="1"
                    Margin="16,0,0,0"
                    Padding="18,16"
                    Background="#121923"
                    BorderBrush="#233240"
                    BorderThickness="1"
                    CornerRadius="14">
                <StackPanel Width="170">
                    <TextBlock Style="{StaticResource MutedTextBlockStyle}" Text="结果数" />
                    <TextBlock x:Name="CountValueTextBlock"
                               Margin="0,10,0,0"
                               Style="{StaticResource ValueTextBlockStyle}"
                               Text="0" />
                </StackPanel>
            </Border>

            <Border Grid.Row="0"
                    Grid.Column="2"
                    Margin="16,0,0,0"
                    Padding="18,16"
                    Background="#121923"
                    BorderBrush="#233240"
                    BorderThickness="1"
                    CornerRadius="14">
                <StackPanel Width="260">
                    <TextBlock Style="{StaticResource MutedTextBlockStyle}" Text="播放来源" />
                    <TextBlock x:Name="SourceValueTextBlock"
                               Margin="0,10,0,0"
                               Style="{StaticResource ValueTextBlockStyle}"
                               Text="未加载"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Border>

            <Border Grid.Row="1"
                    Grid.ColumnSpan="3"
                    Margin="0,16,0,0"
                    Padding="18,16"
                    Background="#121923"
                    BorderBrush="#233240"
                    BorderThickness="1"
                    CornerRadius="14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock VerticalAlignment="Top"
                               Style="{StaticResource MutedTextBlockStyle}"
                               Text="本地文件" />
                    <TextBlock x:Name="PathValueTextBlock"
                               Grid.Column="1"
                               Margin="16,0,0,0"
                               TextWrapping="Wrap"
                               Foreground="#D7E3EE" />
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Margin="0,18,0,0"
                Padding="12"
                Background="#121923"
                BorderBrush="#233240"
                BorderThickness="1"
                CornerRadius="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock x:Name="StatusValueTextBlock"
                           Margin="8,6,8,12"
                           FontSize="14"
                           Foreground="#B7C6D3"
                           Text="等待加载..." />

                <ListView x:Name="ResultsListView"
                          Grid.Row="1"
                          BorderThickness="0"
                          Background="Transparent"
                          Foreground="#F3F8FD"
                                                    ItemContainerStyle="{StaticResource ResultsListViewItemStyle}"
                          KeyDown="ResultsListView_OnKeyDown"
                          MouseDoubleClick="ResultsListView_OnMouseDoubleClick"
                                                    SelectionMode="Single"
                          ScrollViewer.CanContentScroll="True"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling">
                    <ListView.View>
                                                <GridView AllowsColumnReorder="False"
                                                                    ColumnHeaderContainerStyle="{StaticResource ResultsGridHeaderStyle}">
                            <GridViewColumn Header="#" Width="70" DisplayMemberBinding="{Binding DisplayIndex}" />
                            <GridViewColumn Header="歌曲" Width="320" DisplayMemberBinding="{Binding Name}" />
                            <GridViewColumn Header="歌手" Width="240" DisplayMemberBinding="{Binding Artist}" />
                            <GridViewColumn Header="专辑" Width="320" DisplayMemberBinding="{Binding Album}" />
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </Border>

        <Border Grid.Row="3"
                Margin="0,18,0,0"
                Padding="16,14"
                Background="#15202B"
                BorderBrush="#233240"
                BorderThickness="1"
                CornerRadius="14">
            <TextBlock x:Name="FooterTextBlock"
                       Foreground="#C9D7E4"
                       Text="结果激活执行链尚未接入，本轮先验证本地解析与检索能力。" />
        </Border>
    </Grid>
</Window>
